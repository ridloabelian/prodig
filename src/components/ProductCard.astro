---
interface Props {
  product: {
    id: string;
    title: string;
    price: number;
    thumbnail: string;
    sellerName: string | null;
    categoryName: string | null;
    categorySlug: string | null;
  };
}

const { product } = Astro.props;

// Format price to IDR
const formattedPrice = new Intl.NumberFormat("id-ID", {
  style: "currency",
  currency: "IDR",
  minimumFractionDigits: 0,
  maximumFractionDigits: 0,
}).format(product.price);
---

<article class="group relative flex flex-col overflow-hidden rounded-[18px] border border-slate-800 bg-slate-900 transition-all duration-[350ms] hover:-translate-y-2 hover:border-violet-500/40 hover:shadow-[0_30px_50px_-28px_rgba(0,0,0,0.85),0_0_0_1px_rgba(212,175,55,0.08)]">
  <!-- Image Section -->
  <div class="relative aspect-[16/10] w-full overflow-hidden bg-gradient-to-br from-slate-850 to-[#0b1018]">
    <img 
      src={product.thumbnail} 
      alt={product.title}
      class="h-full w-full object-cover transition-transform duration-[600ms] group-hover:scale-[1.07]"
      loading="lazy"
    />
    {product.categoryName && (
      <span class="absolute top-3 left-3 z-[2] rounded-full bg-black/60 px-3 py-1 text-[11.5px] font-bold text-white backdrop-blur-sm border border-white/10">
        {product.categoryName}
      </span>
    )}
  </div>

  <!-- Content Section -->
  <div class="flex flex-1 flex-col p-[18px]">
    <div class="mb-[7px] text-xs text-slate-400">
      oleh <span class="font-semibold text-slate-300">{product.sellerName || "Kreator"}</span>
    </div>
    <h3 class="mb-4 line-clamp-2 text-base font-bold leading-snug text-slate-100 transition-colors duration-300 group-hover:text-violet-300">
      <a href={`/products/${product.id}`} class="focus:outline-none">
        <span class="absolute inset-0" aria-hidden="true"></span>
        {product.title}
      </a>
    </h3>
    
    <div class="mt-auto flex items-center justify-between border-t border-slate-800 pt-4">
      <span class="font-display text-lg font-extrabold text-violet-400" style="font-family: var(--font-display);">
        {formattedPrice}
      </span>
      <span class="inline-flex items-center rounded-[10px] bg-violet-500/15 px-[14px] py-[9px] text-xs font-bold text-violet-300 transition-colors duration-300 group-hover:bg-gradient-to-r group-hover:from-violet-400 group-hover:to-violet-500 group-hover:text-[#1a1505]">
        Beli Sekarang
      </span>
    </div>
  </div>
</article>
