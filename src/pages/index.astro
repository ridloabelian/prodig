---
import { env } from "cloudflare:workers";
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import { getDb } from "../db";
import { products, categories, users } from "../db/schema";
import { eq, desc } from "drizzle-orm";

let productsList: any[] = [];
let categoriesList: any[] = [];
let errorMsg = "";

try {
  // Bindings D1 diakses melalui env
  const db = getDb(env);

  productsList = await db
    .select({
      id: products.id,
      title: products.title,
      price: products.price,
      thumbnail: products.thumbnail,
      sellerName: users.name,
      categoryName: categories.name,
      categorySlug: categories.slug,
    })
    .from(products)
    .leftJoin(users, eq(products.sellerId, users.id))
    .leftJoin(categories, eq(products.categoryId, categories.id))
    .where(eq(products.status, "APPROVED"))
    .orderBy(desc(products.createdAt))
    .limit(8);

  categoriesList = await db
    .select()
    .from(categories)
    .orderBy(categories.name);
} catch (e: any) {
  console.error("Gagal memuat data dari database D1:", e);
  errorMsg = e.message;
}
---

<Layout title="Prodig - Marketplace Produk Digital Tercepat">
  <!-- Navbar -->
  <nav class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between">
        <div class="flex items-center">
          <a href="/" class="flex items-center gap-2">
            <span class="bg-gradient-to-r from-violet-400 to-indigo-500 bg-clip-text text-2xl font-extrabold text-transparent tracking-wider">
              PRODIG
            </span>
            <span class="rounded bg-violet-600/10 px-2 py-0.5 text-[10px] font-bold text-violet-400 border border-violet-500/20">
              Cloudflare Native
            </span>
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/products" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
            Jelajahi
          </a>
          <a href="/login" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
            Masuk
          </a>
          <a href="/register" class="rounded-xl bg-violet-600 px-4 py-2 text-sm font-bold text-white shadow-lg shadow-violet-500/20 transition-all hover:bg-violet-500 hover:shadow-violet-500/30">
            Mulai Jualan
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <header class="relative overflow-hidden pt-24 pb-20">
    <!-- Ambient Glow Background -->
    <div class="absolute top-1/4 left-1/2 -z-10 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-violet-600/20 blur-3xl"></div>
    <div class="absolute top-1/3 left-1/3 -z-10 h-72 w-72 rounded-full bg-indigo-600/10 blur-3xl"></div>

    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="mx-auto max-w-4xl text-5xl font-extrabold tracking-tight text-white sm:text-6xl md:text-7xl">
        Marketplace Produk Digital 
        <span class="bg-gradient-to-r from-violet-500 via-violet-400 to-violet-600 bg-clip-text text-transparent">
          Tercepat & Efisien
        </span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300">
        Jual dan beli e-book, template bisnis, course, preset, font, dan produk digital premium dari kreator lokal tanpa lemot.
      </p>
      
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/products" class="rounded-xl bg-violet-600 px-8 py-4 text-base font-bold text-white shadow-lg shadow-violet-500/20 transition-all hover:bg-violet-500 hover:shadow-violet-500/30">
          Jelajahi Produk
        </a>
        <a href="/register" class="rounded-xl border border-slate-800 bg-slate-900/50 px-8 py-4 text-base font-bold text-slate-300 backdrop-blur-sm transition-all hover:border-slate-700 hover:text-white">
          Mulai Jualan
        </a>
      </div>
    </div>
  </header>

  <!-- Categories Section -->
  <section class="py-16 bg-slate-950/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold uppercase tracking-wider text-slate-400 mb-8">
        Kategori Terpopuler
      </h2>
      
      {errorMsg && (
        <div class="rounded-2xl border border-red-500/20 bg-red-500/10 p-4 text-red-400 text-sm">
          <strong>Database Error:</strong> {errorMsg}. Pastikan binding D1 lokal / remote sudah berjalan dengan benar.
        </div>
      )}

      {!errorMsg && (
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7">
          {categoriesList.map((cat) => (
            <a 
              href={`/products?category=${cat.slug}`}
              class="group flex flex-col items-center rounded-2xl border border-slate-800 bg-slate-900/20 p-5 text-center transition-all duration-300 hover:border-violet-500/30 hover:bg-slate-900/60"
            >
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-violet-600/10 text-2xl text-violet-400 border border-violet-500/10 transition-transform duration-300 group-hover:scale-110">
                📦
              </div>
              <span class="mt-4 text-xs font-bold text-slate-300 group-hover:text-violet-300 transition-colors">
                {cat.name}
              </span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Featured Products Section -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h2 class="text-3xl font-extrabold text-white">
            Produk Digital Terbaru
          </h2>
          <p class="mt-2 text-sm text-slate-400">
            Dapatkan produk berkualitas siap pakai dari kreator pilihan.
          </p>
        </div>
        <a href="/products" class="group flex items-center gap-1 text-sm font-bold text-violet-400 hover:text-violet-300 transition-colors">
          Lihat Semua 
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>

      {productsList.length === 0 && !errorMsg && (
        <div class="rounded-2xl border border-slate-800 bg-slate-900/10 p-12 text-center">
          <p class="text-slate-400">Belum ada produk yang disetujui untuk ditampilkan saat ini.</p>
        </div>
      )}

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {productsList.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="relative py-24 overflow-hidden border-t border-slate-900 bg-slate-900/10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-3xl font-extrabold text-white mb-16">
        Kemudahan Bertransaksi di Prodig
      </h2>
      <div class="grid gap-12 md:grid-cols-3">
        <div class="flex flex-col items-center text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-violet-600/15 border border-violet-500/20 text-3xl">
            📤
          </div>
          <h3 class="mt-6 text-lg font-bold text-slate-100">1. Kreator Mengunggah</h3>
          <p class="mt-3 text-sm text-slate-400 max-w-xs">
            Seller mengunggah berkas produk digital beserta detail informasi, harga, dan thumbnail produk.
          </p>
        </div>
        
        <div class="flex flex-col items-center text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-violet-600/15 border border-violet-500/20 text-3xl">
            💳
          </div>
          <h3 class="mt-6 text-lg font-bold text-slate-100">2. Pembayaran Instan</h3>
          <p class="mt-3 text-sm text-slate-400 max-w-xs">
            Buyer membayar dengan aman menggunakan QRIS, e-wallet, atau Virtual Account via gateway pembayaran Mayar.id.
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-violet-600/15 border border-violet-500/20 text-3xl">
            ⚡
          </div>
          <h3 class="mt-6 text-lg font-bold text-slate-100">3. Unduhan Langsung</h3>
          <p class="mt-3 text-sm text-slate-400 max-w-xs">
            Setelah sukses, pembeli langsung mendapatkan akses download instan dan salinan berkas ter-watermark otomatis.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-slate-900 py-12 bg-slate-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center text-slate-500 text-xs">
      <p>&copy; {new Date().getFullYear()} PRODIG. Hak Cipta Dilindungi. Didukung penuh oleh infrastruktur Cloudflare Edge.</p>
    </div>
  </footer>
</Layout>
