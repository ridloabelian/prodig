---
import { env } from "cloudflare:workers";
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import { getDb } from "../db";
import { products, categories, users } from "../db/schema";
import { eq, desc } from "drizzle-orm";

let productsList: any[] = [];
let categoriesList: any[] = [];
let errorMsg = "";

try {
  const db = getDb(env);

  productsList = await db
    .select({
      id: products.id,
      title: products.title,
      price: products.price,
      thumbnail: products.thumbnail,
      sellerName: users.name,
      categoryName: categories.name,
      categorySlug: categories.slug,
    })
    .from(products)
    .leftJoin(users, eq(products.sellerId, users.id))
    .leftJoin(categories, eq(products.categoryId, categories.id))
    .where(eq(products.status, "APPROVED"))
    .orderBy(desc(products.createdAt))
    .limit(8);

  categoriesList = await db
    .select()
    .from(categories)
    .orderBy(categories.name);
} catch (e: any) {
  console.error("Gagal memuat data dari database D1:", e);
  errorMsg = e.message;
}

// SVG Lucide icons mapping
const iconMap: Record<string, string> = {
  "e-book": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  "course": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  "kursus": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  "font": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>`,
  "preset": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" y1="4" x2="14" y2="4"/><line x1="10" y1="4" x2="3" y2="4"/><line x1="21" y1="12" x2="12" y2="12"/><line x1="8" y1="12" x2="3" y2="12"/><line x1="21" y1="20" x2="16" y2="20"/><line x1="12" y1="20" x2="3" y2="20"/><line x1="14" y1="2" x2="14" y2="6"/><line x1="8" y1="10" x2="8" y2="14"/><line x1="16" y1="18" x2="16" y2="22"/></svg>`,
  "template": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M8 13h2"/><path d="M8 17h2"/><path d="M14 13h2"/><path d="M14 17h2"/></svg>`,
  "spreadsheet": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M8 13h2"/><path d="M8 17h2"/><path d="M14 13h2"/><path d="M14 17h2"/></svg>`,
  "lainnya": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>`,
  "default": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
};

function getCategoryIcon(slug: string, name: string): string {
  const key = slug.toLowerCase();
  if (iconMap[key]) return iconMap[key];
  // fuzzy match by name
  const nameLower = name.toLowerCase();
  if (nameLower.includes("book") || nameLower.includes("e-book") || nameLower.includes("ebook")) return iconMap["e-book"];
  if (nameLower.includes("course") || nameLower.includes("kursus")) return iconMap["course"];
  if (nameLower.includes("font")) return iconMap["font"];
  if (nameLower.includes("preset")) return iconMap["preset"];
  if (nameLower.includes("template") || nameLower.includes("spreadsheet")) return iconMap["template"];
  if (nameLower.includes("lain")) return iconMap["lainnya"];
  return iconMap["default"];
}
---

<Layout title="Prodig - Marketplace Produk Digital Indonesia">
  <!-- ==================== NAVBAR ==================== -->
  <nav class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between">
        <div class="flex items-center">
          <a href="/" class="flex items-center gap-2">
            <span class="bg-gradient-to-r from-violet-400 to-violet-500 bg-clip-text text-2xl font-extrabold text-transparent tracking-wider">
              PRODIG
            </span>
            <span class="rounded-md bg-violet-500/10 px-2 py-0.5 text-xs font-bold text-violet-400 border border-violet-500/20">
              Marketplace Digital
            </span>
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/products" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
            Katalog
          </a>
          <a href="/login" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
            Masuk
          </a>
          <a href="/register" class="rounded-xl bg-violet-500 px-4 py-2 text-sm font-bold text-slate-950 shadow-lg shadow-violet-500/20 transition-all hover:bg-violet-400 hover:shadow-violet-500/30">
            Buka Toko Digital
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- ==================== HERO ==================== -->
  <header class="relative overflow-hidden pt-24 pb-20">
    <!-- Radial gradient glow behind headline -->
    <div class="absolute top-1/3 left-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-violet-500/5 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-violet-400/5 blur-3xl"></div>

    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h1 class="mx-auto max-w-4xl text-5xl font-extrabold tracking-tight text-white sm:text-6xl md:text-7xl" style="letter-spacing: -0.02em;">
        Beli Produk Digital,
        <span class="bg-gradient-to-r from-violet-400 via-violet-500 to-violet-600 bg-clip-text text-transparent">
          Langsung Dipakai
        </span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300 leading-relaxed">
        Produk digital premium dari kreator Indonesia. Bayar via QRIS atau e-wallet, file dikirim otomatis dalam hitungan detik.
      </p>
      
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/products" class="rounded-xl bg-violet-500 px-8 py-4 text-base font-bold text-slate-950 shadow-lg shadow-violet-500/20 transition-all hover:bg-violet-400 hover:shadow-violet-500/30">
          Lihat Katalog
        </a>
        <a href="/register" class="rounded-xl border border-violet-500/40 bg-violet-500/10 px-8 py-4 text-base font-bold text-violet-400 backdrop-blur-sm transition-all hover:bg-violet-500/20 hover:border-violet-400/60 hover:text-violet-300">
          Buka Toko Digital
        </a>
      </div>
    </div>
  </header>

  <!-- ==================== CATEGORIES ==================== -->
  <section class="py-16 bg-slate-900/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold uppercase tracking-wider text-slate-400 mb-8">
        Jelajahi Kategori
      </h2>
      
      {errorMsg && (
        <div class="rounded-2xl border border-red-500/20 bg-red-500/10 p-4 text-red-400 text-sm">
          <strong>Database Error:</strong> {errorMsg}. Pastikan binding D1 lokal / remote sudah berjalan dengan benar.
        </div>
      )}

      {!errorMsg && (
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {categoriesList.map((cat) => {
            const svg = getCategoryIcon(cat.slug, cat.name);
            return (
              <a 
                href={`/products?category=${cat.slug}`}
                class="group flex flex-col items-center rounded-2xl border border-slate-800 bg-slate-900/50 p-5 text-center transition-all duration-300 hover:-translate-y-1 hover:border-violet-500/40 hover:bg-slate-900/80 hover:shadow-lg hover:shadow-violet-500/10"
              >
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-violet-500/10 text-violet-400 border border-violet-500/10 transition-transform duration-300 group-hover:scale-110">
                  <span class="block w-6 h-6" set:html={svg} />
                </div>
                <span class="mt-4 text-xs font-bold text-slate-300 group-hover:text-violet-300 transition-colors">
                  {cat.name}
                </span>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- ==================== FEATURED PRODUCTS ==================== -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-extrabold text-white tracking-tight">
            Produk Pilihan Minggu Ini
          </h2>
          <p class="mt-2 text-sm text-slate-400">
            Template, course, dan asset digital yang telah kami verifikasi kualitasnya.
          </p>
        </div>
        <a href="/products" class="group flex items-center gap-1 text-sm font-bold text-violet-400 hover:text-violet-300 transition-colors">
          Lihat Semua 
          <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
        </a>
      </div>

      {productsList.length === 0 && !errorMsg && (
        <div class="rounded-2xl border border-slate-800 bg-slate-900/10 p-12 text-center">
          <p class="text-slate-400">Belum ada produk yang disetujui untuk ditampilkan saat ini.</p>
        </div>
      )}

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {productsList.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="relative py-24 overflow-hidden border-t border-slate-800 bg-slate-900/30">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-3xl font-extrabold text-white mb-16 tracking-tight">
        Transaksi Aman & Cepat
      </h2>
      
      <div class="relative grid gap-12 md:grid-cols-3">
        {/* Connector lines — desktop only */}
        <div class="hidden md:block absolute top-16 left-[16.67%] right-[16.67%]">
          <div class="flex items-center justify-between">
            <div class="w-full h-px border-t border-dashed border-slate-700"></div>
            <div class="w-full h-px border-t border-dashed border-slate-700"></div>
          </div>
        </div>

        <!-- Step 1 -->
        <div class="relative flex flex-col items-center text-center z-10">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-violet-500/20 to-violet-600/10 border border-violet-500/20 text-violet-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <h3 class="mt-6 text-lg font-bold text-slate-100">1. Upload Produk</h3>
          <p class="mt-3 text-sm text-slate-400 max-w-xs leading-relaxed">
            Kreator upload sekali.
          </p>
        </div>
        
        <!-- Step 2 -->
        <div class="relative flex flex-col items-center text-center z-10">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-violet-500/20 to-violet-600/10 border border-violet-500/20 text-violet-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <h3 class="mt-6 text-lg font-bold text-slate-100">2. Bayar via QRIS / E-Wallet</h3>
          <p class="mt-3 text-sm text-slate-400 max-w-xs leading-relaxed">
            QRIS, e-wallet, atau transfer VA. Pembayaran terverifikasi otomatis.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative flex flex-col items-center text-center z-10">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-violet-500/20 to-violet-600/10 border border-violet-500/20 text-violet-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </div>
          <h3 class="mt-6 text-lg font-bold text-slate-100">3. Download Otomatis</h3>
          <p class="mt-3 text-sm text-slate-400 max-w-xs leading-relaxed">
            File dikirim langsung ke email & dashboard.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FOOTER ==================== -->
  <footer class="border-t border-slate-800 bg-slate-950 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Brand -->
        <div class="lg:col-span-1">
          <a href="/" class="inline-flex items-center gap-2">
            <span class="bg-gradient-to-r from-violet-400 to-violet-500 bg-clip-text text-xl font-extrabold text-transparent tracking-wider">
              PRODIG
            </span>
          </a>
          <p class="mt-3 text-sm text-slate-400 leading-relaxed">
            Marketplace produk digital lokal. Pembayaran QRIS. Support bahasa Indonesia.
          </p>
        </div>

        {/* Navigation */}
        <div>
          <h4 class="text-sm font-bold text-slate-200 uppercase tracking-wider mb-4">Navigasi</h4>
          <ul class="space-y-2">
            <li><a href="/products" class="text-sm text-slate-400 hover:text-violet-400 transition-colors">Lihat Katalog</a></li>
            <li><a href="/register" class="text-sm text-slate-400 hover:text-violet-400 transition-colors">Buka Toko Digital</a></li>
            <li><a href="/login" class="text-sm text-slate-400 hover:text-violet-400 transition-colors">Masuk</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-sm font-bold text-slate-200 uppercase tracking-wider mb-4">Legal</h4>
          <ul class="space-y-2">
            <li><a href="#" class="text-sm text-slate-400 hover:text-violet-400 transition-colors">Syarat & Ketentuan</a></li>
            <li><a href="#" class="text-sm text-slate-400 hover:text-violet-400 transition-colors">Kebijakan Privasi</a></li>
            <li><a href="#" class="text-sm text-slate-400 hover:text-violet-400 transition-colors">Kontak</a></li>
          </ul>
        </div>

        {/* Trust Signal */}
        <div>
          <h4 class="text-sm font-bold text-slate-200 uppercase tracking-wider mb-4">Keamanan</h4>
          <div class="flex items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/50 px-4 py-3">
            <svg class="w-6 h-6 text-violet-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
              <p class="text-xs font-bold text-slate-200">Transaksi Aman</p>
              <p class="text-[11px] text-slate-500">Enkripsi standar industri</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 border-t border-slate-800/80 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
        <p class="text-xs text-slate-500">
          &copy; {new Date().getFullYear()} PRODIG. Hak Cipta Dilindungi.
        </p>
        <p class="text-xs text-slate-600">
          Transaksi aman dengan enkripsi standar industri.
        </p>
      </div>
    </div>
  </footer>
</Layout>
