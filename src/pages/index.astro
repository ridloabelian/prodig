      .hero-word, .hero-fade, .float-card-enter { opacity: 1 !important; animation: none !important; }
      .reveal { opacity: 1; transform: none; }
      .marquee-track { animation: none; }
      .float-wrap, .float-wrap-slow, .float-wrap-slower { animation: none; }
