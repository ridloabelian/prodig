  { slug: "font-typography", label: "Font & Typography", icon: Type },
  { slug: "ai-prompt-pack", label: "AI Prompt Pack", icon: Sparkles },
  { slug: "lainnya", label: "Lainnya", icon: LayoutGrid },
];

const TESTIMONIALS = [
  { q: "File langsung ke email setelah bayar QRIS. Nggak perlu nunggu admin, ini yang aku cari dari dulu.", name: "Sasha W.", role: "Content Creator", av: "1562904403-a5106bef8319" },
