---
import { env } from "cloudflare:workers";
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import { getDb } from "../db";
import { products, categories, users } from "../db/schema";
import { eq, desc } from "drizzle-orm";

let productsList: any[] = [];
let errorMsg = "";

try {
  const db = getDb(env);

  productsList = await db
    .select({
      id: products.id,
      title: products.title,
      price: products.price,
      thumbnail: products.thumbnail,
      sellerName: users.name,
      categoryName: categories.name,
      categorySlug: categories.slug,
    })
    .from(products)
    .leftJoin(users, eq(products.sellerId, users.id))
    .leftJoin(categories, eq(products.categoryId, categories.id))
    .where(eq(products.status, "APPROVED"))
    .orderBy(desc(products.createdAt))
    .limit(8);
} catch (e: any) {
  console.error("Gagal memuat data dari database D1:", e);
  errorMsg = e.message;
}

// Lucide icons
import { GraduationCap, Palette, BookOpen, SlidersHorizontal, CalendarDays, Type, Sparkles, LayoutGrid } from 'lucide';
import defaultAttributes from 'lucide/dist/esm/defaultAttributes.mjs';

function iconToSvg(iconNode: any[], customAttrs: Record<string, string | number> = {}) {
  const attrs = { ...defaultAttributes, ...customAttrs };
  const attrString = Object.entries(attrs)
    .map(([k, v]) => `${k}="${String(v).replace(/"/g, '&quot;')}"`)
    .join(' ');
  const children = iconNode
    .map(([tag, tagAttrs]: [string, Record<string, string>]) => {
      const childAttrs = Object.entries(tagAttrs)
        .map(([k, v]) => `${k}="${String(v).replace(/"/g, '&quot;')}"`)
        .join(' ');
      return `<${tag} ${childAttrs} />`;
    })
    .join('');
  return `<svg ${attrString}>${children}</svg>`;
}

const CATEGORY_ITEMS = [
  { slug: "course", label: "Course & Tutorial", icon: GraduationCap },
  { slug: "template-desain-grafis", label: "Template Desain Grafis", icon: Palette },
