  // 3. Initialize Forms from State
  function syncStateToForm() {
    if (!elements.slug) return;
    elements.slug.value = state.slug;
    elements.title.value = state.title;
    elements.subtitle.value = state.subtitle;
    elements.status.value = state.status;
    elements.heroTitle.value = state.heroTitle;
    elements.heroSubtitle.value = state.heroSubtitle;
    elements.heroFeatures.value = state.heroFeatures.join(", ");
    
    // Highlight correct theme button
    document.querySelectorAll(".theme-select-btn").forEach((btn: any) => {
      const btnTheme = btn.getAttribute("data-theme");
      if (btnTheme === state.theme) {
        btn.classList.add("border-violet-500/80", "bg-violet-950/20");
        btn.classList.remove("border-slate-800");
      } else {
        btn.classList.remove("border-violet-500/80", "bg-violet-950/20");
        btn.classList.add("border-slate-800");
      }
    });

    renderFeaturesForm();
    renderTestimonialsForm();
    renderFaqsForm();
    renderPreview();
    updateLiveViewBtn();
  }

  function updateLiveViewBtn() {
    if (existingLp && elements.viewLiveBtn) {
      elements.viewLiveBtn.href = `/lp/${state.slug}`;
      elements.viewLiveBtn.classList.remove("hidden");
      elements.viewLiveBtn.classList.add("flex");
    }
  }

