  // Helper: Escape HTML strings to prevent breaking layout injection
  function escapeHtml(text: string) {
    if (!text) return "";
    return text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  // 4. Input Change Event Listeners
  function setupFormListeners() {
    if (!elements.slug) return;
    
    elements.slug.addEventListener("input", (e: any) => {
      state.slug = slugify(e.target.value);
      e.target.value = state.slug;
    });

    elements.title.addEventListener("input", (e: any) => {
      state.title = e.target.value;
      renderPreview();
    });

    elements.subtitle.addEventListener("input", (e: any) => {
      state.subtitle = e.target.value;
      renderPreview();
    });

    elements.status.addEventListener("change", (e: any) => {
      state.status = e.target.value;
    });

    elements.heroTitle.addEventListener("input", (e: any) => {
      state.heroTitle = e.target.value;
      renderPreview();
    });

    elements.heroSubtitle.addEventListener("input", (e: any) => {
      state.heroSubtitle = e.target.value;
      renderPreview();
    });

    elements.heroFeatures.addEventListener("input", (e: any) => {
      state.heroFeatures = e.target.value.split(",").map((s: string) => s.trim()).filter(Boolean);
      renderPreview();
    });

    // Theme selector buttons
    document.querySelectorAll(".theme-select-btn").forEach((btn: any) => {
      btn.addEventListener("click", (e: any) => {
        const selectedTheme = btn.getAttribute("data-theme");
        state.theme = selectedTheme;
        
        // Remove highlight from all
        document.querySelectorAll(".theme-select-btn").forEach((b: any) => {
          b.classList.remove("border-violet-500/80", "bg-violet-950/20");
          b.classList.add("border-slate-800");
        });
        
        // Add to clicked
        btn.classList.add("border-violet-500/80", "bg-violet-950/20");
        btn.classList.remove("border-slate-800");
        
        renderPreview();
      });
    });

    // Add list items
    elements.addFeature.addEventListener("click", () => {
      state.features.push({ title: "Keunggulan Baru", description: "Penjelasan detail keunggulan.", icon: "zap" });
      renderFeaturesForm();
      renderPreview();
    });

    elements.addTestimonial.addEventListener("click", () => {
      state.testimonials.push({ name: "Nama Pembeli", role: "Pembeli", content: "Isi testimoni positif di sini.", rating: 5 });
      renderTestimonialsForm();
      renderPreview();
    });

    elements.addFaq.addEventListener("click", () => {
      state.faqs.push({ question: "Pertanyaan baru?", answer: "Jawaban detail pertanyaan di sini." });
      renderFaqsForm();
      renderPreview();
    });

    // Device toggling
    elements.deviceDesktop.addEventListener("click", () => {
      elements.previewViewport.classList.remove("max-w-md");
      elements.deviceDesktop.classList.add("text-white", "bg-slate-900");
      elements.deviceMobile.classList.remove("text-white", "bg-slate-900");
    });

    elements.deviceMobile.addEventListener("click", () => {
      elements.previewViewport.classList.add("max-w-md");
      elements.deviceMobile.classList.add("text-white", "bg-slate-900");
      elements.deviceDesktop.classList.remove("text-white", "bg-slate-900");
    });
  }

  // 5. API Call Handler: AI generation
  async function setupAiGeneration() {
    if (!elements.generateBtn) return;
    
    elements.generateBtn.addEventListener("click", async () => {
      const prompt = elements.aiPrompt.value.trim();
      
      // UI Loading state
      elements.generateBtn.disabled = true;
      const spinner = elements.generateBtn.querySelector(".spinner");
      const btnText = elements.generateBtn.querySelector(".btn-text");
      
      if (spinner && btnText) {
        spinner.classList.remove("hidden");
        btnText.textContent = "Sedang Membangun Copy Page...";
      }

      try {
        const response = await fetch("/api/landingpages/generate", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ productId, prompt })
        });
        
        const resData = await response.json();
        
        if (!response.ok || resData.error) {
          throw new Error(resData.error || "Gagal melakukan AI generation");
        }

        const aiData = resData.data;

        // Apply generated AI copywriter data to state
        state.title = aiData.title || state.title;
        state.subtitle = aiData.subtitle || state.subtitle;
        state.heroTitle = aiData.heroTitle || state.heroTitle;
        state.heroSubtitle = aiData.heroSubtitle || state.heroSubtitle;
        state.heroFeatures = aiData.heroFeatures || state.heroFeatures;
        state.features = aiData.features || state.features;
        state.testimonials = aiData.testimonials || state.testimonials;
        state.faqs = aiData.faqs || state.faqs;

        // Sync inputs & preview
        syncStateToForm();
        showToast("Halaman berhasil dibangun dengan AI Copywriter! ✨");
      } catch (err: any) {
        alert(err.message || "Gagal menghubungkan ke AI Copywriter.");
      } finally {
        elements.generateBtn.disabled = false;
        if (spinner && btnText) {
          spinner.classList.add("hidden");
          btnText.textContent = "Generate ulang dengan AI ✨";
        }
      }
    });
  }

  // 6. Save Landing Page handler
  async function setupSaveHandler() {
    if (!elements.saveBtn) return;
    
    elements.saveBtn.addEventListener("click", async () => {
      elements.saveBtn.disabled = true;
      elements.saveBtn.textContent = "Menyimpan...";

      try {
        const response = await fetch("/api/landingpages", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            productId: state.productId,
            slug: state.slug,
            title: state.title,
            subtitle: state.subtitle,
            theme: state.theme,
            prompt: elements.aiPrompt.value,
            status: state.status,
            heroTitle: state.heroTitle,
            heroSubtitle: state.heroSubtitle,
            heroFeatures: state.heroFeatures,
            features: state.features,
            testimonials: state.testimonials,
            faqs: state.faqs
          })
        });

        const resData = await response.json();
        if (!response.ok || resData.error) {
          throw new Error(resData.error || "Gagal menyimpan landing page");
        }

        showToast("Landing page berhasil disimpan! 🚀");
        
        // Refresh live button if it is a new LP
        if (!existingLp) {
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          updateLiveViewBtn();
        }
      } catch (err: any) {
        alert(err.message || "Gagal menyimpan data.");
      } finally {
        elements.saveBtn.disabled = false;
        elements.saveBtn.textContent = "Simpan Halaman";
      }
    });
  }

  // Toast notification alert helper
  function showToast(msg: string) {
    if (!elements.toast) return;
    elements.toastMsg.textContent = msg;
    elements.toast.classList.remove("hidden");
    elements.toast.classList.add("flex");
    
    setTimeout(() => {
      elements.toast.classList.add("hidden");
      elements.toast.classList.remove("flex");
    }, 3000);
  }

  // Initial boot
  document.addEventListener("DOMContentLoaded", () => {
    syncStateToForm();
    setupFormListeners();
    setupAiGeneration();
    setupSaveHandler();
  });
</script>
