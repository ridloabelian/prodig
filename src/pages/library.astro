---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { getDb } from "../db";
import { transactions, products, users, reviews } from "../db/schema";
import { eq, and, desc } from "drizzle-orm";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login?redirect=" + encodeURIComponent(Astro.url.pathname));
}

let purchases: any[] = [];
let errorMsg = "";

try {
  const db = getDb(Astro.locals.runtime.env);

  // Fetch PAID transactions for this buyer with product, seller, and optional review info
  purchases = await db
    .select({
      id: transactions.id,
      amount: transactions.amount,
      createdAt: transactions.createdAt,
      status: transactions.status,
      product: {
        id: products.id,
        title: products.title,
        thumbnail: products.thumbnail,
        fileName: products.fileName,
        fileSize: products.fileSize,
        fileKey: products.fileKey,
      },
      seller: {
        name: users.name,
      },
      watermarkedFileKey: transactions.watermarkedFileKey,
      review: {
        id: reviews.id,
        rating: reviews.rating,
        comment: reviews.comment,
      },
    })
    .from(transactions)
    .leftJoin(products, eq(transactions.productId, products.id))
    .leftJoin(users, eq(products.sellerId, users.id))
    .leftJoin(reviews, eq(transactions.id, reviews.transactionId))
    .where(
      and(
        eq(transactions.buyerId, user.id),
        eq(transactions.status, "PAID")
      )
    )
    .orderBy(desc(transactions.createdAt));
} catch (e: any) {
  console.error("Gagal memuat perpustakaan pembeli:", e);
  errorMsg = e.message;
}
---

<Layout title="Perpustakaan Saya - Prodig">
  <!-- Navbar -->
  <nav class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between">
        <div class="flex items-center">
          <a href="/" class="flex items-center gap-2">
            <span class="bg-gradient-to-r from-violet-400 to-indigo-500 bg-clip-text text-2xl font-extrabold text-transparent tracking-wider">
              PRODIG
            </span>
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/products" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
            Jelajahi
          </a>
          {user.role === "SELLER" || user.role === "ADMIN" ? (
            <a href="/dashboard" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
              Dashboard Seller
            </a>
          ) : (
            <a href="/register" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
              Mulai Jualan
            </a>
          )}
          <span class="text-sm text-slate-400">|</span>
          <span class="text-sm font-bold text-slate-200">{user.name}</span>
          <button 
            id="logout-btn"
            class="rounded-xl border border-slate-800 bg-slate-900/50 px-3 py-1.5 text-xs font-bold text-slate-350 transition-all hover:border-slate-700 hover:text-white"
          >
            Keluar
          </button>
        </div>
      </div>
    </div>
  </nav>

  <main class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="space-y-8">
      <div>
        <h1 class="text-3xl font-extrabold text-white leading-tight">Library Saya</h1>
        <p class="mt-2 text-sm text-slate-400">Tempat penyimpanan permanen untuk semua produk digital premium yang telah Anda beli.</p>
      </div>

      {errorMsg && (
        <div class="rounded-2xl border border-red-500/20 bg-red-500/10 p-4 text-red-400 text-sm">
          <strong>Database Error:</strong> {errorMsg}
        </div>
      )}

      {purchases.length === 0 && !errorMsg && (
        <div class="rounded-2xl border border-slate-800 bg-slate-900/10 p-16 text-center max-w-xl mx-auto space-y-6">
          <div class="text-5xl">📚</div>
          <h2 class="text-xl font-bold text-white">Library Anda Masih Kosong</h2>
          <p class="text-slate-400 text-sm">Anda belum membeli produk digital apapun. Jelajahi katalog kami untuk menemukan berkas digital berkualitas.</p>
          <a href="/products" class="inline-block rounded-xl bg-violet-600 px-6 py-3 text-sm font-bold text-white hover:bg-violet-500 transition-colors">
            Mulai Belanja
          </a>
        </div>
      )}

      {purchases.length > 0 && (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {purchases.map((trx) => (
            <div class="flex flex-col overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40 shadow-xl backdrop-blur-xl transition-all duration-300 hover:border-slate-700">
              <!-- Thumbnail -->
              <div class="aspect-video w-full overflow-hidden bg-slate-950 relative">
                <img 
                  src={trx.product.thumbnail} 
                  alt={trx.product.title} 
                  class="h-full w-full object-cover"
                />
                {trx.watermarkedFileKey && (
                  <span class="absolute top-2 left-2 rounded bg-violet-600/90 backdrop-blur-sm px-2 py-0.5 text-[9px] font-bold text-white tracking-wider">
                    📄 WATERMARKED PDF
                  </span>
                )}
              </div>

              <!-- Content -->
              <div class="flex flex-1 flex-col p-6 space-y-4">
                <div class="flex-1 space-y-2">
                  <h3 class="font-bold text-white text-base line-clamp-2 min-h-[3rem]">
                    {trx.product.title}
                  </h3>
                  <div class="flex flex-col space-y-1 text-xs text-slate-400">
                    <span>oleh <span class="text-slate-200 font-medium">{trx.seller?.name || "Kreator"}</span></span>
                    <span>Dibeli pada {new Date(trx.createdAt).toLocaleDateString("id-ID", { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                  </div>

                  <!-- File Info -->
                  <div class="rounded-lg bg-slate-950/60 p-2.5 text-[11px] text-slate-400 border border-slate-800/50 flex justify-between gap-2">
                    <span class="truncate block max-w-[150px] font-mono">{trx.product.fileName || "N/A"}</span>
                    <span class="font-medium shrink-0">
                      {trx.product.fileSize ? `${(trx.product.fileSize / (1024 * 1024)).toFixed(2)} MB` : "N/A"}
                    </span>
                  </div>
                </div>

                <!-- Actions -->
                <div class="space-y-2.5">
                  <a 
                    href={`/api/download?trx_id=${trx.id}`}
                    class="flex w-full justify-center items-center rounded-xl bg-gradient-to-r from-violet-600 to-indigo-600 py-3 text-sm font-bold text-white hover:from-violet-500 hover:to-indigo-500 shadow-md transition-all text-center"
                  >
                    Unduh Berkas
                  </a>

                  <!-- Review Section -->
                  {trx.review ? (
                    <div class="rounded-xl border border-slate-800 bg-slate-900/10 p-3 text-xs space-y-1">
                      <div class="flex items-center justify-between">
                        <span class="text-slate-500 font-semibold">Ulasan Anda</span>
                        <span class="text-yellow-500">{"★".repeat(trx.review.rating)}</span>
                      </div>
                      {trx.review.comment && (
                        <p class="text-slate-400 italic line-clamp-2">"{trx.review.comment}"</p>
                      )}
                    </div>
                  ) : (
                    <button 
                      type="button"
                      class="open-review-btn w-full rounded-xl border border-slate-800 bg-slate-900/20 py-2.5 text-xs font-bold text-slate-300 hover:text-white transition-all hover:bg-slate-900/60"
                      data-trx-id={trx.id}
                      data-product-title={trx.product.title}
                      data-cooldown-expired={new Date(new Date(trx.createdAt).getTime() + 60 * 60 * 1000) < new Date() ? "true" : "false"}
                      data-cooldown-mins={Math.max(0, Math.ceil((new Date(trx.createdAt).getTime() + 60 * 60 * 1000 - Date.now()) / 60000))}
                    >
                      Tulis Ulasan
                    </button>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </main>

  <!-- Review Modal Overlay -->
  <div id="review-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/80 backdrop-blur-sm hidden p-4">
    <div class="w-full max-w-md rounded-2xl border border-slate-800 bg-slate-900 p-6 shadow-2xl space-y-6">
      <div class="flex justify-between items-start">
        <div>
          <h3 class="text-lg font-bold text-white">Tulis Ulasan Produk</h3>
          <p id="modal-product-title" class="text-xs text-slate-400 mt-1 line-clamp-1"></p>
        </div>
        <button id="close-modal-btn" class="text-slate-400 hover:text-white text-xl font-bold">&times;</button>
      </div>

      <div id="modal-error" class="hidden rounded-xl border border-red-500/20 bg-red-500/10 p-3 text-xs text-red-400"></div>

      <form id="review-form" class="space-y-4">
        <input type="hidden" id="modal-trx-id" name="transactionId" />

        <!-- Star Rating Input -->
        <div class="space-y-2">
          <label class="block text-sm font-semibold text-slate-300">Rating Ulasan</label>
          <div class="flex gap-2 text-2xl text-slate-600" id="star-rating-container">
            <button type="button" class="star-btn transition-colors hover:text-yellow-400" data-value="1">★</button>
            <button type="button" class="star-btn transition-colors hover:text-yellow-400" data-value="2">★</button>
            <button type="button" class="star-btn transition-colors hover:text-yellow-400" data-value="3">★</button>
            <button type="button" class="star-btn transition-colors hover:text-yellow-400" data-value="4">★</button>
            <button type="button" class="star-btn transition-colors hover:text-yellow-400" data-value="5">★</button>
          </div>
          <input type="hidden" id="modal-rating" name="rating" required />
        </div>

        <!-- Comment Input -->
        <div class="space-y-2">
          <label for="modal-comment" class="block text-sm font-semibold text-slate-300">Komentar Ulasan</label>
          <textarea 
            id="modal-comment" 
            name="comment" 
            rows="4" 
            required 
            minlength="10"
            placeholder="Tulis ulasan jujur Anda tentang produk ini (Min. 10 karakter)..."
            class="block w-full rounded-xl border border-slate-800 bg-slate-950 px-4 py-3 text-xs text-slate-100 placeholder-slate-500 outline-none focus:border-violet-500"
          ></textarea>
        </div>

        <!-- Submit Button -->
        <button 
          type="submit" 
          id="submit-review-btn"
          class="w-full rounded-xl bg-violet-600 py-3 text-sm font-bold text-white hover:bg-violet-500 disabled:opacity-50"
        >
          Kirim Ulasan
        </button>
      </form>
    </div>
  </div>

  <!-- Client-side Logout & Review handling -->
  <script is:inline>
    // Logout handling
    const logoutBtn = document.getElementById("logout-btn");
    if (logoutBtn) {
      logoutBtn.addEventListener("click", async () => {
        if (!confirm("Apakah Anda yakin ingin keluar dari akun Anda?")) return;
        logoutBtn.disabled = true;
        try {
          const res = await fetch("/api/auth/logout", { method: "POST" });
          if (res.ok) {
            window.location.href = "/login";
          } else {
            alert("Gagal keluar. Silakan coba lagi.");
            logoutBtn.disabled = false;
          }
        } catch (err) {
          console.error("Gagal keluar:", err);
          logoutBtn.disabled = false;
        }
      });
    }

    // Review Modal handling
    const modal = document.getElementById("review-modal");
    const modalProductTitle = document.getElementById("modal-product-title");
    const modalTrxId = document.getElementById("modal-trx-id");
    const modalRating = document.getElementById("modal-rating");
    const modalComment = document.getElementById("modal-comment");
    const modalError = document.getElementById("modal-error");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const reviewForm = document.getElementById("review-form");
    const submitReviewBtn = document.getElementById("submit-review-btn");
    const starBtns = document.querySelectorAll(".star-btn");

    // Open Modal
    document.querySelectorAll(".open-review-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const trxId = btn.getAttribute("data-trx-id");
        const productTitle = btn.getAttribute("data-product-title");
        const isCooldownExpired = btn.getAttribute("data-cooldown-expired") === "true";
        const cooldownMins = btn.getAttribute("data-cooldown-mins");

        if (!isCooldownExpired) {
          alert(`Ulasan dibatasi cooldown. Silakan tunggu ${cooldownMins} menit lagi.`);
          return;
        }

        modalProductTitle.textContent = productTitle;
        modalTrxId.value = trxId;
        modalRating.value = "";
        modalComment.value = "";
        modalError.classList.add("hidden");
        modalError.textContent = "";
        
        // Reset stars
        resetStars();

        modal.classList.remove("hidden");
      });
    });

    // Close Modal
    closeModalBtn.addEventListener("click", () => {
      modal.classList.add("hidden");
    });
    modal.addEventListener("click", (e) => {
      if (e.target === modal) modal.classList.add("hidden");
    });

    // Star Selection
    starBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        const val = parseInt(btn.getAttribute("data-value"));
        modalRating.value = val;
        
        starBtns.forEach((sBtn, idx) => {
          if (idx < val) {
            sBtn.classList.remove("text-slate-600");
            sBtn.classList.add("text-yellow-500");
          } else {
            sBtn.classList.remove("text-yellow-500");
            sBtn.classList.add("text-slate-600");
          }
        });
      });
    });

    function resetStars() {
      starBtns.forEach(btn => {
        btn.classList.remove("text-yellow-500");
        btn.classList.add("text-slate-600");
      });
    }

    // Submit Review Form
    reviewForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      modalError.classList.add("hidden");
      modalError.textContent = "";

      const ratingVal = modalRating.value;
      if (!ratingVal) {
        modalError.textContent = "Silakan pilih rating bintang terlebih dahulu.";
        modalError.classList.remove("hidden");
        return;
      }

      submitReviewBtn.disabled = true;
      submitReviewBtn.textContent = "Mengirim...";

      try {
        const res = await fetch("/api/reviews", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            transactionId: modalTrxId.value,
            rating: parseInt(ratingVal),
            comment: modalComment.value,
          }),
        });

        const data = await res.json();

        if (!res.ok) {
          modalError.textContent = data.error || "Gagal mengirim ulasan.";
          modalError.classList.remove("hidden");
          submitReviewBtn.disabled = false;
          submitReviewBtn.textContent = "Kirim Ulasan";
        } else {
          // Success: reload to update view
          window.location.reload();
        }
      } catch (err) {
        console.error("Gagal mengirim ulasan:", err);
        modalError.textContent = "Gangguan koneksi ke server.";
        modalError.classList.remove("hidden");
        submitReviewBtn.disabled = false;
        submitReviewBtn.textContent = "Kirim Ulasan";
      }
    });
  </script>

  <!-- Footer -->
  <footer class="border-t border-slate-900 py-12 bg-slate-950 mt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center text-slate-500 text-xs">
      <p>&copy; {new Date().getFullYear()} PRODIG. Hak Cipta Dilindungi. Didukung penuh oleh infrastruktur Cloudflare Edge.</p>
    </div>
  </footer>
</Layout>
