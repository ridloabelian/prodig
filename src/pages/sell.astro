---
import { env } from "cloudflare:workers";
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { getDb } from "../db";
import { categories } from "../db/schema";

let categoriesList: any[] = [];
let errorMsg = "";

try {
  const db = getDb(env);
  categoriesList = await db
    .select()
    .from(categories)
    .orderBy(categories.name);
} catch (e: any) {
  console.error("Gagal mengambil kategori untuk form jualan:", e);
  errorMsg = e.message;
}
---

<Layout title="Mulai Jualan Produk Digital - Prodig">
  <!-- Navbar -->
  <nav class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between">
        <div class="flex items-center">
          <a href="/" class="flex items-center gap-2">
            <span class="bg-gradient-to-r from-violet-400 to-indigo-500 bg-clip-text text-2xl font-extrabold text-transparent tracking-wider">
              PRODIG
            </span>
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/products" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
            Jelajahi
          </a>
          <a href="/dashboard" class="text-sm font-bold text-violet-400">
            Dashboard
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="space-y-6">
      <div>
        <h1 class="text-3xl font-extrabold text-white leading-tight">Jual Produk Baru</h1>
        <p class="mt-2 text-sm text-slate-400">Unggah karya digital terbaik Anda dan mulailah menghasilkan pendapatan dari internet.</p>
      </div>

      {errorMsg && (
        <div class="rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-red-400 text-sm">
          <strong>Database Error:</strong> {errorMsg}
        </div>
      )}

      <!-- Main Form Container -->
      <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-8 shadow-2xl backdrop-blur-xl">
        <div id="form-error" class="hidden mb-6 rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm text-red-400"></div>

        <form id="sell-form" class="space-y-6">
          
          <!-- Product Title -->
          <div>
            <label for="title" class="block text-sm font-semibold text-slate-300">
              Judul Produk Digital
            </label>
            <input 
              id="title" 
              name="title" 
              type="text" 
              required 
              placeholder="e.g. Template Laporan Keuangan Excel Lengkap"
              class="mt-2 block w-full rounded-xl border border-slate-800 bg-slate-950 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 outline-none transition-all focus:border-violet-500 focus:ring-1 focus:ring-violet-500"
            />
          </div>

          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <!-- Category Selector -->
            <div>
              <label for="categoryId" class="block text-sm font-semibold text-slate-300">
                Kategori
              </label>
              <select 
                id="categoryId" 
                name="categoryId"
                required
                class="mt-2 block w-full rounded-xl border border-slate-800 bg-slate-950 px-4 py-3 text-sm text-slate-300 outline-none transition-all focus:border-violet-500 focus:ring-1 focus:ring-violet-500"
              >
                <option value="">Pilih Kategori...</option>
                {categoriesList.map((cat) => (
                  <option value={cat.id}>{cat.name}</option>
                ))}
              </select>
            </div>

            <!-- Price in Rupiah -->
            <div>
              <label for="price" class="block text-sm font-semibold text-slate-300">
                Harga Jual <span class="text-xs text-slate-500 font-normal">(Rupiah)</span>
              </label>
              <input 
                id="price" 
                name="price" 
                type="number" 
                required 
                min="10000"
                placeholder="e.g. 50000"
                class="mt-2 block w-full rounded-xl border border-slate-800 bg-slate-950 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 outline-none transition-all focus:border-violet-500 focus:ring-1 focus:ring-violet-500"
              />
            </div>
          </div>

          <!-- Product Description -->
          <div>
            <label for="description" class="block text-sm font-semibold text-slate-300">
              Deskripsi Produk <span class="text-xs text-slate-500 font-normal">(Min. 50 karakter)</span>
            </label>
            <textarea 
              id="description" 
              name="description" 
              required 
              rows="6"
              placeholder="Berikan deskripsi detail tentang produk Anda, kegunaan, format file, panduan instalasi, dan apa saja yang didapatkan oleh pembeli..."
              class="mt-2 block w-full rounded-xl border border-slate-800 bg-slate-950 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 outline-none transition-all focus:border-violet-500 focus:ring-1 focus:ring-violet-500 resize-y"
            ></textarea>
          </div>

          <!-- UPLOAD FIELD 1: PRODUCT DIGITAL FILE -->
          <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 p-6 space-y-4">
            <h3 class="text-sm font-bold text-slate-200">1. Unggah File Produk Digital</h3>
            <p class="text-xs text-slate-400">Hanya format PDF, ZIP, MP4, Excel, Word, atau EPUB. Maksimal 500MB.</p>
            
            <div class="flex items-center gap-4">
              <input 
                type="file" 
                id="product-file-input" 
                accept=".pdf,.zip,.mp4,.xlsx,.docx,.epub"
                class="hidden" 
              />
              <button 
                type="button" 
                id="product-file-trigger"
                class="rounded-xl border border-slate-800 bg-slate-900 px-4 py-2.5 text-xs font-bold text-slate-300 hover:text-white"
              >
                Pilih File Produk...
              </button>
              <span id="product-file-status" class="text-xs text-slate-500 truncate max-w-xs">Belum ada file dipilih</span>
            </div>

            <!-- Upload progress bar -->
            <div id="product-progress-container" class="hidden space-y-1">
              <div class="h-1.5 w-full bg-slate-900 rounded-full overflow-hidden">
                <div id="product-progress-bar" class="h-full bg-violet-600 w-0 transition-all"></div>
              </div>
              <span id="product-progress-text" class="text-[10px] text-violet-400 font-bold block">0% terunggah</span>
            </div>

            <!-- Hidden file inputs to submit -->
            <input type="hidden" id="fileKey" name="fileKey" />
            <input type="hidden" id="fileName" name="fileName" />
            <input type="hidden" id="fileSize" name="fileSize" />
          </div>

          <!-- UPLOAD FIELD 2: THUMBNAIL IMAGE -->
          <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 p-6 space-y-4">
            <h3 class="text-sm font-bold text-slate-200">2. Unggah Gambar Thumbnail Produk</h3>
            <p class="text-xs text-slate-400">Gunakan format JPEG, PNG, JPG, atau WEBP. Maksimal 2MB.</p>
            
            <div class="flex items-center gap-4">
              <input 
                type="file" 
                id="thumbnail-input" 
                accept="image/jpeg,image/png,image/webp,image/jpg"
                class="hidden" 
              />
              <button 
                type="button" 
                id="thumbnail-trigger"
                class="rounded-xl border border-slate-800 bg-slate-900 px-4 py-2.5 text-xs font-bold text-slate-300 hover:text-white"
              >
                Pilih Gambar...
              </button>
              <span id="thumbnail-status" class="text-xs text-slate-500 truncate max-w-xs">Belum ada gambar dipilih</span>
            </div>

            <!-- Thumbnail upload progress bar -->
            <div id="thumbnail-progress-container" class="hidden space-y-1">
              <div class="h-1.5 w-full bg-slate-900 rounded-full overflow-hidden">
                <div id="thumbnail-progress-bar" class="h-full bg-violet-600 w-0 transition-all"></div>
              </div>
              <span id="thumbnail-progress-text" class="text-[10px] text-violet-400 font-bold block">0% terunggah</span>
            </div>

            <!-- Preview image if uploaded -->
            <div id="thumbnail-preview-container" class="hidden max-w-[200px] rounded-lg overflow-hidden border border-slate-800">
              <img id="thumbnail-preview" class="w-full object-cover aspect-video" />
            </div>

            <input type="hidden" id="thumbnail" name="thumbnail" />
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            id="submit-form-btn"
            class="relative flex w-full justify-center rounded-xl bg-violet-600 py-4 text-base font-bold text-white shadow-lg shadow-violet-500/20 transition-all hover:bg-violet-500 hover:shadow-violet-500/30 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Kirim untuk Moderasi (Approval)
          </button>
        </form>
      </div>
    </div>
  </main>

  <!-- Client-side Direct R2 Presigned Upload XHR script -->
  <script is:inline>
    // Elements product file
    const productFileInput = document.getElementById("product-file-input");
    const productFileTrigger = document.getElementById("product-file-trigger");
    const productFileStatus = document.getElementById("product-file-status");
    const productProgressContainer = document.getElementById("product-progress-container");
    const productProgressBar = document.getElementById("product-progress-bar");
    const productProgressText = document.getElementById("product-progress-text");
    const fileKeyInput = document.getElementById("fileKey");
    const fileNameInput = document.getElementById("fileName");
    const fileSizeInput = document.getElementById("fileSize");

    // Elements thumbnail image
    const thumbnailInput = document.getElementById("thumbnail-input");
    const thumbnailTrigger = document.getElementById("thumbnail-trigger");
    const thumbnailStatus = document.getElementById("thumbnail-status");
    const thumbnailProgressContainer = document.getElementById("thumbnail-progress-container");
    const thumbnailProgressBar = document.getElementById("thumbnail-progress-bar");
    const thumbnailProgressText = document.getElementById("thumbnail-progress-text");
    const thumbnailPreviewContainer = document.getElementById("thumbnail-preview-container");
    const thumbnailPreview = document.getElementById("thumbnail-preview");
    const thumbnailInputHidden = document.getElementById("thumbnail");

    // General Form Elements
    const sellForm = document.getElementById("sell-form");
    const formError = document.getElementById("form-error");
    const submitFormBtn = document.getElementById("submit-form-btn");

    // Triggers click
    productFileTrigger.addEventListener("click", () => productFileInput.click());
    thumbnailTrigger.addEventListener("click", () => thumbnailInput.click());

    // File Upload Handler (Promise-based XHR PUT)
    async function uploadToR2(file, type, statusEl, progressContainer, progressBar, progressText) {
      statusEl.textContent = `Menyiapkan berkas...`;
      progressContainer.classList.remove("hidden");
      progressBar.style.width = "0%";
      progressText.textContent = "0% terunggah";

      try {
        // 1. Fetch Presigned URL
        const res = await fetch("/api/upload/presigned", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            fileName: file.name,
            fileType: file.type,
            fileSize: file.size,
            type: type,
          }),
        });

        const data = await res.json();
        if (!res.ok) {
          throw new Error(data.error || "Gagal mendapatkan izin unggah.");
        }

        const { uploadUrl, fileKey, publicUrl } = data;

        // 2. Perform direct XHR PUT
        return new Promise((resolve, reject) => {
          const xhr = new XMLHttpRequest();
          xhr.open("PUT", uploadUrl, true);
          xhr.setRequestHeader("Content-Type", file.type);

          xhr.upload.onprogress = (e) => {
            if (e.lengthComputable) {
              const percentComplete = Math.round((e.loaded / e.total) * 100);
              progressBar.style.width = `${percentComplete}%`;
              progressText.textContent = `${percentComplete}% terunggah`;
              statusEl.textContent = `Mengunggah berkas (${percentComplete}%)...`;
            }
          };

          xhr.onload = () => {
            if (xhr.status === 200) {
              statusEl.textContent = `Selesai: ${file.name}`;
              progressBar.classList.add("bg-green-500");
              resolve({ fileKey, publicUrl });
            } else {
              reject(new Error(`Gagal mengunggah berkas. Status: ${xhr.status}`));
            }
          };

          xhr.onerror = () => reject(new Error("Gangguan koneksi saat mengunggah."));
          xhr.send(file);
        });

      } catch (err) {
        statusEl.textContent = `Error: ${err.message}`;
        progressBar.classList.add("bg-red-500");
        progressContainer.classList.add("hidden");
        throw err;
      }
    }

    // Product File Input Change
    productFileInput.addEventListener("change", async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      submitFormBtn.disabled = true;
      try {
        const { fileKey } = await uploadToR2(
          file, 
          "product", 
          productFileStatus, 
          productProgressContainer, 
          productProgressBar, 
          productProgressText
        );
        fileKeyInput.value = fileKey;
        fileNameInput.value = file.name;
        fileSizeInput.value = file.size;
      } catch (err) {
        alert(err.message);
      } finally {
        checkFormEnableState();
      }
    });

    // Thumbnail Input Change
    thumbnailInput.addEventListener("change", async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      submitFormBtn.disabled = true;
      try {
        const { fileKey, publicUrl } = await uploadToR2(
          file, 
          "thumbnail", 
          thumbnailStatus, 
          thumbnailProgressContainer, 
          thumbnailProgressBar, 
          thumbnailProgressText
        );
        thumbnailInputHidden.value = publicUrl;
        
        // Show preview
        thumbnailPreview.src = publicUrl;
        thumbnailPreviewContainer.classList.remove("hidden");
      } catch (err) {
        alert(err.message);
      } finally {
        checkFormEnableState();
      }
    });

    function checkFormEnableState() {
      // Form is submittable if both fileKey and thumbnail have values
      if (fileKeyInput.value && thumbnailInputHidden.value) {
        submitFormBtn.disabled = false;
      } else {
        submitFormBtn.disabled = true;
      }
    }

    // Initially disable submit button
    checkFormEnableState();

    // Form Submission
    sellForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      formError.classList.add("hidden");
      formError.textContent = "";

      submitFormBtn.disabled = true;
      const originalText = submitFormBtn.textContent;
      submitFormBtn.textContent = "Mengirim...";

      const formData = new FormData(sellForm);
      const title = formData.get("title");
      const categoryId = formData.get("categoryId");
      const price = parseInt(formData.get("price"));
      const description = formData.get("description");
      const fileKey = fileKeyInput.value;
      const fileName = fileNameInput.value;
      const fileSize = parseInt(fileSizeInput.value);
      const thumbnail = thumbnailInputHidden.value;

      try {
        const res = await fetch("/api/products", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            title,
            categoryId,
            price,
            description,
            fileKey,
            fileName,
            fileSize,
            thumbnail,
          }),
        });

        const data = await res.json();

        if (!res.ok) {
          formError.textContent = data.error || "Gagal menyimpan produk digital.";
          formError.classList.remove("hidden");
          submitFormBtn.disabled = false;
          submitFormBtn.textContent = originalText;
        } else {
          // Successfully created product: redirect to dashboard
          window.location.href = "/dashboard";
        }
      } catch (err) {
        console.error("Gagal mengirim form:", err);
        formError.textContent = "Gangguan koneksi server. Gagal mengirim data produk.";
        formError.classList.remove("hidden");
        submitFormBtn.disabled = false;
        submitFormBtn.textContent = originalText;
      }
    });
  </script>

  <!-- Footer -->
  <footer class="border-t border-slate-900 py-12 bg-slate-950 mt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center text-slate-500 text-xs">
      <p>&copy; {new Date().getFullYear()} PRODIG. Hak Cipta Dilindungi. Didukung penuh oleh infrastruktur Cloudflare Edge.</p>
    </div>
  </footer>
</Layout>
