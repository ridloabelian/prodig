---
import { env } from "cloudflare:workers";
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { getDb } from "../../db";
import { products, categories, users } from "../../db/schema";
import { eq, and, or, like, desc, asc } from "drizzle-orm";

// Get query parameters from URL
const q = Astro.url.searchParams.get("q") || "";
const category = Astro.url.searchParams.get("category") || "";
const sort = Astro.url.searchParams.get("sort") || "newest";

let productsList: any[] = [];
let categoriesList: any[] = [];
let errorMsg = "";

try {
  const db = getDb(env);

  // 1. Fetch Categories for Sidebar
  categoriesList = await db
    .select()
    .from(categories)
    .orderBy(categories.name);

  // 2. Build Products Query with Filters
  let conditions: any[] = [eq(products.status, "APPROVED")];

  if (q) {
    conditions.push(
      or(
        like(products.title, `%${q}%`),
        like(products.description, `%${q}%`)
      )
    );
  }

  if (category) {
    conditions.push(eq(categories.slug, category));
  }

  let baseQuery = db
    .select({
      id: products.id,
      title: products.title,
      price: products.price,
      thumbnail: products.thumbnail,
      sellerName: users.name,
      categoryName: categories.name,
      categorySlug: categories.slug,
    })
    .from(products)
    .leftJoin(users, eq(products.sellerId, users.id))
    .leftJoin(categories, eq(products.categoryId, categories.id))
    .where(and(...conditions));

  // Apply Sorting
  if (sort === "price_asc") {
    productsList = await baseQuery.orderBy(asc(products.price));
  } else if (sort === "price_desc") {
    productsList = await baseQuery.orderBy(desc(products.price));
  } else if (sort === "popular") {
    productsList = await baseQuery.orderBy(desc(products.salesCount));
  } else {
    productsList = await baseQuery.orderBy(desc(products.createdAt));
  }
} catch (e: any) {
  console.error("Gagal mengambil produk dari database:", e);
  errorMsg = e.message;
}
---

<Layout title="Jelajahi Produk - Prodig Marketplace">
  <!-- Navbar -->
  <nav class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between">
        <div class="flex items-center">
          <a href="/" class="flex items-center gap-2">
            <span class="bg-gradient-to-r from-violet-400 to-indigo-500 bg-clip-text text-2xl font-extrabold text-transparent tracking-wider">
              PRODIG
            </span>
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/products" class="text-sm font-bold text-violet-400">
            Jelajahi
          </a>
          {Astro.locals.user ? (
            <span class="text-sm text-slate-300">
              Halo, <span class="font-bold text-slate-100">{Astro.locals.user.name}</span>
            </span>
            <a href="/dashboard" class="rounded-xl border border-slate-800 bg-slate-900/50 px-4 py-2 text-sm font-bold text-slate-300 transition-all hover:border-slate-700 hover:text-white">
              Dashboard
            </a>
          ) : (
            <a href="/login" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
              Masuk
            </a>
            <a href="/register" class="rounded-xl bg-violet-600 px-4 py-2 text-sm font-bold text-white shadow-lg shadow-violet-500/20 transition-all hover:bg-violet-500 hover:shadow-violet-500/30">
              Mulai Jualan
            </a>
          )}
        </div>
      </div>
    </div>
  </nav>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-8 lg:flex-row">
      <!-- Sidebar Filters (Desktop) & Top Filter Accordion (Mobile) -->
      <aside class="w-full lg:w-64 flex-shrink-0">
        <div class="sticky top-24 space-y-6 rounded-2xl border border-slate-800 bg-slate-900/20 p-6 backdrop-blur-sm">
          <div>
            <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-4">
              Kategori
            </h3>
            <ul class="space-y-2">
              <li>
                <a 
                  href={`/products?q=${q}&sort=${sort}`}
                  class={`flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors ${!category ? 'bg-violet-600/10 text-violet-400 font-bold border border-violet-500/10' : 'text-slate-400 hover:bg-slate-900 hover:text-slate-200'}`}
                >
                  Semua Produk
                </a>
              </li>
              {categoriesList.map((cat) => (
                <li>
                  <a 
                    href={`/products?category=${cat.slug}&q=${q}&sort=${sort}`}
                    class={`flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors ${category === cat.slug ? 'bg-violet-600/10 text-violet-400 font-bold border border-violet-500/10' : 'text-slate-400 hover:bg-slate-900 hover:text-slate-200'}`}
                  >
                    {cat.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </aside>

      <!-- Products Listing and Search -->
      <div class="flex-grow">
        <!-- Search, Sort & Title Area -->
        <div class="mb-8 rounded-2xl border border-slate-800 bg-slate-900/20 p-6 backdrop-blur-sm">
          <h1 class="text-2xl font-extrabold text-white mb-6">Jelajahi Produk Digital</h1>
          
          <form method="GET" action="/products" class="flex flex-col gap-4 sm:flex-row sm:items-center">
            {category && <input type="hidden" name="category" value={category} />}
            
            <div class="relative flex-grow">
              <input 
                type="text" 
                name="q" 
                value={q} 
                placeholder="Cari e-book, template excel, course..."
                class="block w-full rounded-xl border border-slate-800 bg-slate-950 pl-10 pr-4 py-3 text-sm text-slate-100 placeholder-slate-500 outline-none transition-all focus:border-violet-500 focus:ring-1 focus:ring-violet-500"
              />
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                <svg class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
            </div>
            
            <div class="flex gap-4">
              <div class="relative min-w-[150px]">
                <select 
                  name="sort" 
                  onchange="this.form.submit()"
                  class="block w-full rounded-xl border border-slate-800 bg-slate-950 px-4 py-3 text-sm text-slate-300 outline-none transition-all focus:border-violet-500 focus:ring-1 focus:ring-violet-500"
                >
                  <option value="newest" selected={sort === "newest"}>Terbaru</option>
                  <option value="popular" selected={sort === "popular"}>Terpopuler</option>
                  <option value="price_asc" selected={sort === "price_asc"}>Harga Terendah</option>
                  <option value="price_desc" selected={sort === "price_desc"}>Harga Tertinggi</option>
                </select>
              </div>
              
              <button 
                type="submit"
                class="rounded-xl bg-violet-600 px-6 py-3 text-sm font-bold text-white hover:bg-violet-500 transition-colors"
              >
                Cari
              </button>
            </div>
          </form>
        </div>

        {errorMsg && (
          <div class="mb-6 rounded-2xl border border-red-500/20 bg-red-500/10 p-4 text-red-400 text-sm">
            <strong>Database Error:</strong> {errorMsg}
          </div>
        )}

        <!-- Products Grid -->
        {!errorMsg && (
          <div>
            {productsList.length === 0 ? (
              <div class="rounded-2xl border border-slate-800 bg-slate-900/10 p-16 text-center">
                <div class="text-4xl mb-4">🔍</div>
                <h3 class="text-lg font-bold text-white">Tidak Ada Produk Ditemukan</h3>
                <p class="mt-2 text-slate-400">
                  Coba kata kunci lain atau pilih kategori yang berbeda.
                </p>
                {(q || category) && (
                  <a href="/products" class="mt-6 inline-block rounded-xl bg-slate-850 px-4 py-2 text-sm font-bold text-slate-300 hover:text-white border border-slate-800">
                    Reset Filter
                  </a>
                )}
              </div>
            ) : (
              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {productsList.map((product) => (
                  <ProductCard product={product} />
                ))}
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-slate-900 py-12 bg-slate-950 mt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center text-slate-500 text-xs">
      <p>&copy; {new Date().getFullYear()} PRODIG. Hak Cipta Dilindungi. Didukung penuh oleh infrastruktur Cloudflare Edge.</p>
    </div>
  </footer>
</Layout>
