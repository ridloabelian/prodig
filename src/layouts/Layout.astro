---
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Prodig - Marketplace Produk Digital" } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-slate-950 text-slate-50 antialiased font-sans">
		<slot />
	</body>
</html>

